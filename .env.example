# Blurt Backend Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── REQUIRED ────────────────────────────────────────────────
# Gemini 2 API (powers voice, classification, embeddings)
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Encryption master key (64 hex chars)
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
BLURT_MASTER_KEY=

# ─── GOOGLE CALENDAR (required for calendar sync) ───────────
# Get from: Google Cloud Console > APIs & Services > Credentials > OAuth 2.0
# Redirect URI: http://localhost:8080/auth/google/callback
BLURT_GOOGLE_CLIENT_ID=
BLURT_GOOGLE_CLIENT_SECRET=

# ─── NEON POSTGRES (required for persistence) ───────────────
# Get from: Neon Console > Connection Details
DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require

# ─── OPTIONAL ────────────────────────────────────────────────
# Notion integration
NOTION_API_TOKEN=

# Deployment mode: "cloud" (default) or "local"
BLURT_MODE=cloud

# Server settings
BLURT_HOST=0.0.0.0
BLURT_PORT=8000
BLURT_DATA_DIR=~/.blurt
BLURT_ENCRYPTION=true
BLURT_DEBUG=false
